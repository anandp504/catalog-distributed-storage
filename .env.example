# Required — Gitea admin credentials (used for Basic auth on all Gitea nodes)
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_PASSWORD=changeme
GITEA_ADMIN_EMAIL=admin@beckn.local

# Required — PostgreSQL connection password (no default; must be set explicitly)
POSTGRES_PASSWORD=changeme

# Optional — PostgreSQL database name and user (defaults shown)
POSTGRES_DB=catalog_routing
POSTGRES_USER=beckn

# Optional — Service ports (defaults shown)
PORT=3000

# Optional — Gitea node URLs (defaults shown for docker-compose topology)
GITEA_NODES=http://gitea-1:3000,http://gitea-2:3000

# Optional — Gitea org name (default shown)
GITEA_ORG=beckn

# Optional — Redis URL (default shown)
REDIS_URL=redis://redis:6379
